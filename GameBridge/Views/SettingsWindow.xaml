<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="GameAudioMixer.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Settings">

    <Grid RequestedTheme="Dark" Background="Transparent">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid x:Name="SettingsTitleBar" Grid.Row="0" Height="44" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="138"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Border Background="#2060A5FA" CornerRadius="6" Padding="5,3">
                    <FontIcon Glyph="&#xE713;" FontSize="10" Foreground="#60A5FA"/>
                </Border>
                <TextBlock Text="Settings" FontSize="12" FontWeight="SemiBold" Opacity="0.5"
                           IsHitTestVisible="False" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" Padding="14,0,14,14">
            <StackPanel Spacing="10" MaxWidth="560">

                <!-- ═══ AUTO-DUCKING ═══ -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel Spacing="14">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Background="#15F59E0B" CornerRadius="6" Padding="5,3">
                                <FontIcon Glyph="&#xE994;" FontSize="12" Foreground="#FBBF24"/>
                            </Border>
                            <TextBlock Text="Smart Auto-Ducking" FontSize="13" FontWeight="SemiBold"
                                       Opacity="0.85" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Automatically reduce game volume when chat is active"
                                       FontSize="11" Opacity="0.4" TextWrapping="Wrap" VerticalAlignment="Center"/>
                            <ToggleSwitch Grid.Column="1" x:Name="DuckingToggle" OnContent="" OffContent="" MinWidth="0"/>
                        </Grid>
                        <StackPanel Spacing="6">
                            <Grid>
                                <TextBlock Text="Volume reduction" FontSize="11" Opacity="0.5"/>
                                <TextBlock x:Name="DuckPercentLabel" Text="" FontSize="11" Opacity="0.3"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                            <Slider x:Name="DuckPercentSlider" Minimum="10" Maximum="80" Value="30"
                                    StepFrequency="5" ValueChanged="OnDuckPercentChanged"/>
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <Grid>
                                <TextBlock Text="Activation threshold" FontSize="11" Opacity="0.5"/>
                                <TextBlock x:Name="DuckThresholdLabel" Text="" FontSize="11" Opacity="0.3"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                            <Slider x:Name="DuckThresholdSlider" Minimum="0.005" Maximum="0.1"
                                    Value="0.01" StepFrequency="0.005" ValueChanged="OnDuckThresholdChanged"/>
                        </StackPanel>

                        <!-- Live ducking monitor -->
                        <Border Background="#08FFFFFF" CornerRadius="12" Padding="14,12">
                            <StackPanel Spacing="10">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE9D9;" FontSize="10" Foreground="#FBBF24" Opacity="0.6"/>
                                        <TextBlock Text="MONITOR" FontSize="9" FontWeight="Bold"
                                                   CharacterSpacing="120" Opacity="0.35"/>
                                    </StackPanel>
                                    <Border x:Name="DuckStateBadge" Background="#15EF4444" CornerRadius="8"
                                            Padding="8,2" HorizontalAlignment="Right">
                                        <TextBlock x:Name="DuckStateText" Text="IDLE" FontSize="8"
                                                   FontWeight="Bold" Foreground="#EF4444" Opacity="0.7"/>
                                    </Border>
                                </Grid>

                                <!-- Chat peak meter -->
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Chat Peak" FontSize="9" Opacity="0.35"/>
                                    <Grid Height="16" CornerRadius="4">
                                        <Border Background="#10FFFFFF" CornerRadius="4"/>
                                        <Border x:Name="ChatPeakBar" Background="#408B5CF6"
                                                CornerRadius="4,0,0,4" HorizontalAlignment="Left" Width="0"/>
                                        <!-- Threshold marker -->
                                        <Border x:Name="ThresholdMarker" Width="2" Height="16"
                                                Background="#80FBBF24" HorizontalAlignment="Left"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                    <Grid>
                                        <TextBlock x:Name="ChatPeakValue" Text="0.000" FontSize="9"
                                                   Opacity="0.25" FontFamily="Cascadia Code, Consolas"/>
                                        <TextBlock x:Name="ThresholdValue" Text="" FontSize="9"
                                                   Opacity="0.25" HorizontalAlignment="Right"
                                                   FontFamily="Cascadia Code, Consolas"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Game volume -->
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Game Volume" FontSize="9" Opacity="0.35"/>
                                    <Grid Height="10" CornerRadius="3">
                                        <Border Background="#10FFFFFF" CornerRadius="3"/>
                                        <Border x:Name="GameVolBar" Background="#4010B981"
                                                CornerRadius="3,0,0,3" HorizontalAlignment="Left"/>
                                    </Grid>
                                    <TextBlock x:Name="GameVolValue" Text="100%" FontSize="9"
                                               Opacity="0.25" FontFamily="Cascadia Code, Consolas"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ═══ HOTKEYS ═══ -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel Spacing="14">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Background="#1560A5FA" CornerRadius="6" Padding="5,3">
                                <FontIcon Glyph="&#xE765;" FontSize="12" Foreground="#60A5FA"/>
                            </Border>
                            <TextBlock Text="Global Hotkeys" FontSize="13" FontWeight="SemiBold"
                                       Opacity="0.85" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Click a combination to change it, then press the new keys. Esc to cancel."
                                   FontSize="11" Opacity="0.35" TextWrapping="Wrap"/>
                        <StackPanel x:Name="HotkeyPanel" Spacing="4"/>
                        <Button Content="Reset to defaults" Click="OnResetHotkeysClick"
                                FontSize="11" Padding="14,6" CornerRadius="10"
                                Background="#14FFFFFF" BorderThickness="0" Foreground="#70FFFFFF"/>
                    </StackPanel>
                </Border>

                <!-- ═══ PREFERRED DEVICES ═══ -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Background="#15EC4899" CornerRadius="6" Padding="5,3">
                                <FontIcon Glyph="&#xE7F5;" FontSize="12" Foreground="#F472B6"/>
                            </Border>
                            <TextBlock Text="Preferred Devices" FontSize="13" FontWeight="SemiBold"
                                       Opacity="0.85" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Select devices to cycle through with the hotkey."
                                   FontSize="11" Opacity="0.35" TextWrapping="Wrap"/>
                        <ListView x:Name="PreferredDeviceList" SelectionMode="Multiple"
                                  SelectionChanged="OnPreferredDevicesChanged" MaxHeight="140" Padding="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FriendlyName}" FontSize="12"/>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <!-- ═══ AUTO-START ═══ -->
                <Border Style="{StaticResource SectionCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="#1510B981" CornerRadius="6" Padding="5,3" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE7E8;" FontSize="12" Foreground="#10B981"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Start with Windows" FontSize="13" FontWeight="SemiBold" Opacity="0.85"/>
                            <TextBlock Text="Launch automatically at login" FontSize="11" Opacity="0.35"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="2" x:Name="AutoStartToggle" Toggled="OnAutoStartToggled"
                                      OnContent="" OffContent="" MinWidth="0"/>
                    </Grid>
                </Border>

                <!-- ═══ GAME PROFILES ═══ -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Background="#158B5CF6" CornerRadius="6" Padding="5,3">
                                <FontIcon Glyph="&#xE7FC;" FontSize="12" Foreground="#8B5CF6"/>
                            </Border>
                            <TextBlock Text="Game Profiles" FontSize="13" FontWeight="SemiBold"
                                       Opacity="0.85" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Saved audio configurations per game, applied automatically."
                                   FontSize="11" Opacity="0.35" TextWrapping="Wrap"/>
                        <ListView x:Name="ProfileList" SelectionMode="None" MaxHeight="180" Padding="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="2,6" ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding ExeName}" VerticalAlignment="Center" FontSize="12"/>
                                        <Button Grid.Column="1" Tag="{Binding ExeName}" Click="OnDeleteProfileClick"
                                                Background="#15EF4444" BorderThickness="0" CornerRadius="8"
                                                Padding="8,4" Height="28">
                                            <FontIcon Glyph="&#xE74D;" FontSize="11" Foreground="#EF4444"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <!-- ═══ SAVE BUTTON ═══ -->
                <Button Content="Save Settings" Click="OnSaveSettingsClick"
                        HorizontalAlignment="Stretch" Height="42" CornerRadius="14"
                        Background="#3060A5FA" Foreground="#60A5FA" FontWeight="SemiBold"
                        FontSize="13" BorderThickness="0" Margin="0,4"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
